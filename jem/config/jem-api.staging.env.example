# Staging API server (install to /etc/friedso/jem-staging.env on VPS — never commit secrets)
JEM_DB_PATH=/srv/friedso/stage/services/jem/data/jem.db
JEM_AUTH_MODE=dev
JEM_SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JEM_BASE_URL=https://staging.friedso.com
JEM_MAP_URL=https://staging.friedso.com/apps/jem
JEM_PUBLIC_API_PREFIX=/api/jem/v1
JEM_OAUTH_REDIRECT_URI=https://staging.friedso.com/api/jem/v1/auth/linkedin/callback
JEM_CORS_ORIGINS=https://staging.friedso.com
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
