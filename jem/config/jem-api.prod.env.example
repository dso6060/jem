# Production API server (install to /etc/friedso/jem-prod.env on VPS — never commit secrets)
JEM_DB_PATH=/srv/friedso/prod/services/jem/data/jem.db
JEM_AUTH_MODE=production
JEM_SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JEM_BASE_URL=https://friedso.com
JEM_MAP_URL=https://friedso.com/apps/jem
JEM_PUBLIC_API_PREFIX=/api/jem/v1
JEM_OAUTH_REDIRECT_URI=https://friedso.com/api/jem/v1/auth/linkedin/callback
JEM_CORS_ORIGINS=https://friedso.com,https://www.friedso.com
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# JEM_MAINTAINER_OAUTH_SUBS=
